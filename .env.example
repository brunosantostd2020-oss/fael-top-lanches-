# Copie este arquivo para .env e preencha os valores

# URL do banco PostgreSQL (Railway fornece isso automaticamente)
DATABASE_URL=postgresql://usuario:senha@host:5432/nomedobanco

# Segredo para gerar tokens de login (pode ser qualquer texto longo)
JWT_SECRET=fael-top-lanches-minha-chave-secreta-2024

# Ambiente
NODE_ENV=production

# ── Z-API (WhatsApp automático para clientes) — OPCIONAL ──
# Sem essas variáveis o site funciona normal, só não envia WhatsApp.
# Pegue os valores no painel da Z-API (https://z-api.io) após conectar o chip.
# IMPORTANTE: use um chip separado do número da loja!
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
